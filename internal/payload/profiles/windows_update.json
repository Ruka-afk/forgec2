{
  "name": "windows_update",
  "description": "Mimics Windows Update traffic",
  "user_agent": "Windows-Update-Agent/10.0.10011.16384 Client-Protocol/1.40",
  "beacon_uri": "/msdownload/update/v3/static/trustedr/en/authrootstl.cab",
  "method": "GET",
  "headers": {
    "Accept": "*/*",
    "Accept-Encoding": "identity",
    "Accept-Language": "en-US",
    "Connection": "Keep-Alive"
  },
  "sleep": 60,
  "jitter": 15
}
